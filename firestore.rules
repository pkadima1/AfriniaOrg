rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check user role
    function getUserRole() {
      return get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return request.auth != null && getUserRole() == 'admin';
    }

    function isContributor() {
      return request.auth != null && getUserRole() in ['admin', 'contributor'];
    }

    function isOwnProfile() {
      return request.auth.uid == resource.id;
    }

    // User profiles - allow first-time creation, own read/write, admin full access
    match /user_profiles/{userId} {
      // Allow user to create their own profile on first login
      allow create: if request.auth.uid == userId && 
                       request.resource.data.email == request.auth.token.email;
      
      // Allow user to read their own profile
      allow read: if request.auth.uid == userId || isAdmin();
      
      // Allow user to update their own profile
      allow update: if request.auth.uid == userId || isAdmin();
      
      // Only admins can delete user profiles
      allow delete: if isAdmin();
    }

    // Blog posts - public read, authenticated write
    match /blog_posts/{postId} {
      // Public read all published blog posts
      allow read: if resource.data.status == 'published' || 
                     (request.auth != null && (isAdmin() || isContributor()));
      
      // Only contributors and admins can create
      allow create: if request.auth != null && isContributor();
      
      // Only post author, contributors, or admins can edit
      allow update: if request.auth != null && 
                       (isAdmin() || 
                        isContributor() ||
                        resource.data.author_id == request.auth.uid);
      
      // Only admins can delete
      allow delete: if isAdmin();
    }

    // Comments - public read, public create, author/admin edit/delete
    match /comments/{commentId} {
      // Public read all comments
      allow read: if true;
      
      // Anyone can create comments
      allow create: if true;
      
      // Author or admin can edit
      allow update: if request.auth != null &&
                       (isAdmin() || 
                        resource.data.author_email == request.auth.token.email);
      
      // Author or admin can delete
      allow delete: if request.auth != null &&
                       (isAdmin() || 
                        resource.data.author_email == request.auth.token.email);
    }

    // Deny access to any other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
